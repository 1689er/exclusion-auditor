# User-owned config may reference local paths / secrets — never commit it.
config.yaml
config.local.yaml

# Confidential audit output — the default (non-sanitized) report contains real
# exclusion values & admin identities. By convention, write it with a
# *.confidential.* suffix so it can never be committed by accident. Sanitized
# --share-out files (e.g. *.sanitized.json) are safe and intentionally NOT ignored.
*.confidential.json
*.confidential.md
*.confidential.txt

# Secrets / credentials — never commit
.env
*.env
*.pem
*.key
*.p12
*.pfx
id_rsa*
credentials.json
secrets.*

# Editor / OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
.pytest_cache/
